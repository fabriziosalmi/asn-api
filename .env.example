# ASN Risk API - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL
POSTGRES_USER=asn_admin
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=asn_registry

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
CLICKHOUSE_DB=default

# API Authentication
API_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Service hostnames (Docker Compose defaults - no need to change)
DB_META_HOST=db-metadata
DB_TS_HOST=db-timeseries
REDIS_HOST=broker-cache
BROKER_URL=redis://broker-cache:6379/0

# API Configuration
CACHE_TTL=60
API_RATE_LIMIT=100
CORS_ORIGINS=*

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
